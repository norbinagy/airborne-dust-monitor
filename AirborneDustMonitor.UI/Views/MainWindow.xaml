<Window x:Class="AirborneDustMonitor.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:AirborneDustMonitor.UI.Views"
        Title="Szenzor vezérlőpult" Height="800" Width="1000"
        WindowState="Maximized" Closed="Window_Closed">
    <Grid Background="#F0F0F0">
        <ItemsControl ItemsSource="{Binding MetricDisplays}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="2" Rows="2" Margin="10"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" 
                            CornerRadius="5" 
                            Margin="5" 
                            BorderBrush="#DCDCDC" 
                            BorderThickness="1">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                        </Border.Effect>
                        <local:MetricDisplayControl />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Button Content="Térkép megnyitása" Command="{Binding OpenMapCommand}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10" Padding="10,5"/>
        <Button Content="Beállítások megnyitása" Command="{Binding OpenSettingsCommand}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10" Padding="10,5"/>
        <Popup Placement="Center" 
            AllowsTransparency="True" 
            PopupAnimation="Fade"
            IsOpen="{Binding IsToastOpen}" 
            StaysOpen="True">
            <Border Background="#333333" CornerRadius="8" Padding="20,10">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding ToastMessage}" Foreground="White"/>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>